# ── PostgreSQL (Docker Compose) ───────────────────────────────────────────────
POSTGRES_USER=booking
POSTGRES_PASSWORD=booking123
POSTGRES_DB=booking_system
DB_PORT=5432

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
BACKEND_PORT=3000

# ── Database (local dev — Docker Compose builds this from PG vars above) ─────
DATABASE_URL=postgresql://booking:booking123@localhost:5432/booking_system

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-secret-key
JWT_REFRESH_SECRET=change-this-refresh-key
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3001
